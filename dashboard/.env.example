# NeuroSwarm AI Dashboard — Environment Variables
# Copy to .env.local and fill in values

# Solana RPC endpoint (overrides default devnet)
# Use a dedicated RPC provider in production (Helius, Triton, etc.)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_WSS_URL=wss://api.devnet.solana.com

# Cluster: devnet | mainnet | localnet
NEXT_PUBLIC_CLUSTER=devnet
