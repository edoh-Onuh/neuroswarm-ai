{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["mocha", "node"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "rootDir": "."
  },
  "include": ["tests/**/*.ts"],
  "exclude": ["node_modules", "dashboard", "mobile"]
}
